{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntityRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "entity_type", "status", "aliases"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "معرف مستقر وحيد، بصيغة kebab-case صغيرة"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "الاسم الرسمي أو الأساسي للكيان"
    },
    "entity_type": {
      "enum": ["person", "organization", "company", "government", "location", "project", "other"],
      "description": "نوع الكيان"
    },
    "status": {
      "enum": ["active", "inactive", "unknown"],
      "description": "حالة الكيان: active (نشط)، inactive (غير نشط)، unknown (غير معروف)"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "قائمة الأسماء البديلة أو الأسماء السابقة للكيان"
    },
    "description": {
      "type": ["string", "null"],
      "minLength": 5,
      "description": "وصف موجز للكيان ودوره أو أهميته"
    },
    "source_ids": {
      "type": ["array", "null"],
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true,
      "description": "قائمة معرفات المصادر التي توثق معلومات عن هذا الكيان"
    }
  }
}
